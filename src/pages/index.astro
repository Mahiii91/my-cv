---
import Layout from '../layouts/Layout.astro';

const profile = {
	name: 'Mahi',
	title: 'Digital Humanities Student',
	location: 'Germany',
	email: 'your.email@example.com',
	summary:
		'I am interested in digital humanities, cultural heritage, historical texts, and the use of web technologies to present research in accessible and thoughtful ways.',
};

const education = [
	{
		degree: 'Your Degree or Program',
		place: 'Your University',
		period: 'Year - Year',
		detail: 'Add your field of study, thesis topic, or academic focus here.',
	},
];

const interests = [
	'Digital humanities',
	'Iranian cultural heritage',
	'Historical texts and inscriptions',
	'Web-based research presentation',
];

const skills = ['HTML', 'CSS', 'Astro', 'Research', 'Academic writing', 'Digital archiving'];

const projects = [
	{
		name: 'Digital Archive of Persian Inscriptions',
		detail:
			'A web project about preserving and presenting the history, language, and cultural significance of Persian inscriptions.',
	},
	{
		name: 'Research Portfolio',
		detail:
			'A personal academic space for sharing research interests, projects, and CV information.',
	},
];
---

<Layout title={`${profile.name} CV`}>
	<main class="page-shell">
		<section class="hero" aria-labelledby="page-title">
			<div>
				<p class="eyebrow">Curriculum Vitae</p>
				<h1 id="page-title">{profile.name}</h1>
				<p class="title">{profile.title}</p>
				<p class="summary">{profile.summary}</p>
			</div>
			<aside class="contact-panel" aria-label="Contact information">
				<p>{profile.location}</p>
				<a href={`mailto:${profile.email}`}>{profile.email}</a>
				<a href="/my-cv-webpage-info.txt">CV source notes</a>
			</aside>
		</section>

		<section class="content-grid" aria-label="CV sections">
			<div class="main-column">
				<section class="section-block">
					<h2>Education</h2>
					{education.map((item) => (
						<article class="timeline-item">
							<p class="period">{item.period}</p>
							<h3>{item.degree}</h3>
							<p class="place">{item.place}</p>
							<p>{item.detail}</p>
						</article>
					))}
				</section>

				<section class="section-block">
					<h2>Projects</h2>
					{projects.map((project) => (
						<article class="project-item">
							<h3>{project.name}</h3>
							<p>{project.detail}</p>
						</article>
					))}
				</section>
			</div>

			<aside class="side-column">
				<section class="section-block">
					<h2>Research Interests</h2>
					<ul class="tag-list">
						{interests.map((interest) => <li>{interest}</li>)}
					</ul>
				</section>

				<section class="section-block">
					<h2>Skills</h2>
					<ul class="tag-list compact">
						{skills.map((skill) => <li>{skill}</li>)}
					</ul>
				</section>
			</aside>
		</section>
	</main>
</Layout>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: #f7f4ef;
		color: #1f2933;
	}

	a {
		color: #22577a;
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	.page-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 32px 0 48px;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: 32px;
		align-items: end;
		padding: 56px 0 40px;
		border-bottom: 1px solid #d8d1c5;
	}

	.eyebrow,
	.period {
		margin: 0 0 10px;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #7b5f39;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 10px;
		font-size: clamp(3rem, 8vw, 6.5rem);
		line-height: 0.95;
		font-weight: 800;
		color: #16212b;
	}

	.title {
		margin-bottom: 22px;
		font-size: 1.35rem;
		color: #36515f;
	}

	.summary {
		max-width: 720px;
		margin-bottom: 0;
		font-size: 1.08rem;
		line-height: 1.7;
		color: #3f4f5a;
	}

	.contact-panel {
		display: grid;
		gap: 10px;
		padding: 18px;
		border: 1px solid #d8d1c5;
		border-radius: 8px;
		background: #fffaf3;
		font-size: 0.96rem;
	}

	.contact-panel p {
		margin: 0;
		color: #5d6871;
	}

	.content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.8fr);
		gap: 40px;
		padding-top: 40px;
	}

	.section-block {
		margin-bottom: 36px;
	}

	h2 {
		margin-bottom: 18px;
		font-size: 1rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #22577a;
	}

	h3 {
		margin-bottom: 6px;
		font-size: 1.25rem;
		color: #16212b;
	}

	.timeline-item,
	.project-item {
		padding: 0 0 24px;
		margin-bottom: 24px;
		border-bottom: 1px solid #ddd6ca;
	}

	.timeline-item p,
	.project-item p {
		line-height: 1.65;
		color: #4b5963;
	}

	.place {
		margin-bottom: 10px;
		font-weight: 700;
		color: #36515f;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.tag-list li {
		padding: 8px 10px;
		border: 1px solid #d6c8b4;
		border-radius: 8px;
		background: #fffaf3;
		color: #344955;
	}

	.tag-list.compact li {
		font-size: 0.92rem;
	}

	@media (max-width: 760px) {
		.page-shell {
			width: min(100% - 24px, 1120px);
			padding-top: 12px;
		}

		.hero,
		.content-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			gap: 24px;
			padding-top: 36px;
		}

		.contact-panel {
			width: 100%;
		}
	}
</style>
