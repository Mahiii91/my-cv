---
import Layout from '../layouts/Layout.astro';

const profile = {
	name: 'Mahboubeh (Mahi) Ramezani',
	title: 'M.A. Iranian Studies Student',
	address: 'Oberlandstrasse 97, 12099 Berlin',
	phone: '+49 175 1500169',
	email: 'mahbouber91@zedat.fu-berlin.de',
	summary:
		'I am an Iranian Studies student with experience in guest services, customer service, language teaching, translation, and intercultural communication. My background combines academic training, hospitality experience, and strong language skills.',
};

const education = [
	{
		degree: 'M.A. Iranian Studies',
		place: 'Freie Universitat Berlin',
		period: 'Since 10/2025',
		detail: 'Current graduate study in Iranian Studies.',
	},
	{
		degree: 'German Language Certificates A1-C1',
		place: 'telc, Berlin',
		period: '2022-2025',
		detail: 'German language certification from beginner to advanced level.',
	},
	{
		degree: 'English-Language Certificate in Tourism and Guest Services',
		place: 'Mashhad, Iran',
		period: '2015',
		detail: 'Training focused on tourism, guest support, and service communication.',
	},
	{
		degree: 'Teacher Training Course (TTC)',
		place: 'Mashhad, Iran',
		period: '08/2014',
		detail: 'Teacher training for English language instruction.',
	},
	{
		degree: 'B.A. English Language and Literature',
		place: 'State University of Neyshabur, Iran',
		period: '2010-2014',
		detail: 'Undergraduate study in English language and literature.',
	},
	{
		degree: 'High School Diploma',
		place: 'Mathematics and Physics Track',
		period: '2008',
		detail: 'Secondary education with a focus on mathematics and physics.',
	},
];

const experience = [
	{
		role: 'Guest Service Employee',
		place: 'Hotel Adlon / Estrel Hotel / Olympiastadion, Berlin',
		period: '2023-2024',
	},
	{
		role: 'Customer Service Employee',
		place: 'Ata Airline, Mashhad Airport, Iran',
		period: '2020-2021',
	},
	{
		role: 'English Instructor and Translator',
		place: 'Bayan English Language Institute, Mashhad, Iran',
		period: '2015-2020',
	},
	{
		role: 'Hotel Assistant',
		place: 'Darvishi Hotel, Mashhad, Iran',
		period: '2014-2017',
	},
];

const skills = [
	'Organizational skills',
	'Strong communication and presentation skills',
	'Intercultural competence and sensitivity',
	'Good MS Office skills: Word, Excel, PowerPoint',
];

const languages = [
	'German - C1 (telc certificate)',
	'English - C1',
	'Arabic - Basic knowledge',
	'Persian - Native language',
];
---

<Layout title={`${profile.name} CV`}>
	<main class="page-shell">
		<section class="hero" aria-labelledby="page-title">
			<div>
				<p class="eyebrow">Curriculum Vitae</p>
				<h1 id="page-title">{profile.name}</h1>
				<p class="title">{profile.title}</p>
				<p class="summary">{profile.summary}</p>
			</div>
			<aside class="contact-panel" aria-label="Contact information">
				<p>{profile.address}</p>
				<a href={`tel:${profile.phone.replaceAll(' ', '')}`}>{profile.phone}</a>
				<a href={`mailto:${profile.email}`}>{profile.email}</a>
				<a href="/my-cv-webpage-info.txt">CV source notes</a>
			</aside>
		</section>

		<section class="content-grid" aria-label="CV sections">
			<div class="main-column">
				<section class="section-block">
					<h2>Education</h2>
					{education.map((item) => (
						<article class="timeline-item">
							<p class="period">{item.period}</p>
							<h3>{item.degree}</h3>
							<p class="place">{item.place}</p>
							<p>{item.detail}</p>
						</article>
					))}
				</section>

				<section class="section-block">
					<h2>Professional Experience</h2>
					{experience.map((job) => (
						<article class="project-item">
							<p class="period">{job.period}</p>
							<h3>{job.role}</h3>
							<p>{job.place}</p>
						</article>
					))}
				</section>
			</div>

			<aside class="side-column">
				<section class="section-block">
					<h2>Skills</h2>
					<ul class="tag-list compact">
						{skills.map((skill) => <li>{skill}</li>)}
					</ul>
				</section>

				<section class="section-block">
					<h2>Languages</h2>
					<ul class="tag-list compact">
						{languages.map((language) => <li>{language}</li>)}
					</ul>
				</section>
			</aside>
		</section>
	</main>
</Layout>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(body) {
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: #f7f4ef;
		color: #1f2933;
	}

	a {
		color: #22577a;
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	.page-shell {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding: 32px 0 48px;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: 32px;
		align-items: end;
		padding: 56px 0 40px;
		border-bottom: 1px solid #d8d1c5;
	}

	.eyebrow,
	.period {
		margin: 0 0 10px;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #7b5f39;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 10px;
		font-size: clamp(3rem, 8vw, 6.5rem);
		line-height: 0.95;
		font-weight: 800;
		color: #16212b;
	}

	.title {
		margin-bottom: 22px;
		font-size: 1.35rem;
		color: #36515f;
	}

	.summary {
		max-width: 720px;
		margin-bottom: 0;
		font-size: 1.08rem;
		line-height: 1.7;
		color: #3f4f5a;
	}

	.contact-panel {
		display: grid;
		gap: 10px;
		padding: 18px;
		border: 1px solid #d8d1c5;
		border-radius: 8px;
		background: #fffaf3;
		font-size: 0.96rem;
	}

	.contact-panel p {
		margin: 0;
		color: #5d6871;
	}

	.content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.8fr);
		gap: 40px;
		padding-top: 40px;
	}

	.section-block {
		margin-bottom: 36px;
	}

	h2 {
		margin-bottom: 18px;
		font-size: 1rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: #22577a;
	}

	h3 {
		margin-bottom: 6px;
		font-size: 1.25rem;
		color: #16212b;
	}

	.timeline-item,
	.project-item {
		padding: 0 0 24px;
		margin-bottom: 24px;
		border-bottom: 1px solid #ddd6ca;
	}

	.timeline-item p,
	.project-item p {
		line-height: 1.65;
		color: #4b5963;
	}

	.place {
		margin-bottom: 10px;
		font-weight: 700;
		color: #36515f;
	}

	.tag-list {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.tag-list li {
		padding: 8px 10px;
		border: 1px solid #d6c8b4;
		border-radius: 8px;
		background: #fffaf3;
		color: #344955;
	}

	.tag-list.compact li {
		font-size: 0.92rem;
	}

	@media (max-width: 760px) {
		.page-shell {
			width: min(100% - 24px, 1120px);
			padding-top: 12px;
		}

		.hero,
		.content-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			gap: 24px;
			padding-top: 36px;
		}

		.contact-panel {
			width: 100%;
		}
	}
</style>
