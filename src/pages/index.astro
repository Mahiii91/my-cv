---
import Layout from '../layouts/Layout.astro';

const profile = {
	name: 'Mahboubeh (Mahi) Ramezani',
	title: 'M.A. Iranian Studies Student',
	address: 'Berlin, Germany',
	email: 'mahbouber91@zedat.fu-berlin.de',
	summary:
		'I am an Iranian Studies student with experience in guest services, customer service, language teaching, translation, and intercultural communication. My background combines academic training, hospitality experience, and strong language skills.',
};

const education = [
	{
		degree: 'M.A. Iranian Studies',
		place: 'Freie Universitat Berlin',
		period: 'Since 10/2025',
		detail: 'Current graduate study in Iranian Studies.',
	},
	{
		degree: 'German Language Certificates A1-C1',
		place: 'telc, Berlin',
		period: '2022-2025',
		detail: 'German language certification from beginner to advanced level.',
	},
	{
		degree: 'English-Language Certificate in Tourism and Guest Services',
		place: 'Mashhad, Iran',
		period: '2015',
		detail: 'Training focused on tourism, guest support, and service communication.',
	},
	{
		degree: 'Teacher Training Course (TTC)',
		place: 'Mashhad, Iran',
		period: '08/2014',
		detail: 'Teacher training for English language instruction.',
	},
	{
		degree: 'B.A. English Language and Literature',
		place: 'State University of Neyshabur, Iran',
		period: '2010-2014',
		detail: 'Undergraduate study in English language and literature.',
	},
	{
		degree: 'High School Diploma',
		place: 'Mathematics and Physics Track',
		period: '2008',
		detail: 'Secondary education with a focus on mathematics and physics.',
	},
];

const experience = [
	{
		role: 'Guest Service Employee',
		place: 'Hotel Adlon / Estrel Hotel / Olympiastadion, Berlin',
		period: '2023-2024',
	},
	{
		role: 'Customer Service Employee',
		place: 'Ata Airline, Mashhad Airport, Iran',
		period: '2020-2021',
	},
	{
		role: 'English Instructor and Translator',
		place: 'Bayan English Language Institute, Mashhad, Iran',
		period: '2015-2020',
	},
	{
		role: 'Hotel Assistant',
		place: 'Darvishi Hotel, Mashhad, Iran',
		period: '2014-2017',
	},
];

const skills = [
	'Organizational skills',
	'Strong communication and presentation skills',
	'Intercultural competence and sensitivity',
	'Good MS Office skills: Word, Excel, PowerPoint',
];

const languages = [
	'German - C1 (telc certificate)',
	'English - C1',
	'Arabic - Basic knowledge',
	'Persian - Native language',
];
---

<Layout title={`${profile.name} CV`}>
	<main class="page-shell">
		<section class="hero" aria-labelledby="page-title">
			<div class="hero-copy">
				<p class="eyebrow">Curriculum Vitae</p>
				<h1 id="page-title">{profile.name}</h1>
				<p class="title">{profile.title}</p>
				<p class="summary">{profile.summary}</p>
			</div>
			<aside class="contact-panel" aria-label="Contact information">
				<div class="monogram" aria-hidden="true">MR</div>
				<p class="panel-label">Contact</p>
				<dl>
					<div>
						<dt>Address</dt>
						<dd>{profile.address}</dd>
					</div>
					<div>
						<dt>Email</dt>
						<dd><a href={`mailto:${profile.email}`}>{profile.email}</a></dd>
					</div>
				</dl>
			</aside>
		</section>

		<section class="content-grid" aria-label="CV sections">
			<div class="main-column">
				<section class="section-block">
					<h2>Education</h2>
					{education.map((item) => (
						<article class="timeline-item">
							<p class="period">{item.period}</p>
							<h3>{item.degree}</h3>
							<p class="place">{item.place}</p>
							<p>{item.detail}</p>
						</article>
					))}
				</section>

				<section class="section-block">
					<h2>Professional Experience</h2>
					{experience.map((job) => (
						<article class="project-item">
							<p class="period">{job.period}</p>
							<h3>{job.role}</h3>
							<p>{job.place}</p>
						</article>
					))}
				</section>
			</div>

			<aside class="side-column">
				<section class="section-block">
					<h2>Skills</h2>
					<ul class="tag-list compact">
						{skills.map((skill) => <li>{skill}</li>)}
					</ul>
				</section>

				<section class="section-block">
					<h2>Languages</h2>
					<ul class="tag-list compact">
						{languages.map((language) => <li>{language}</li>)}
					</ul>
				</section>
			</aside>
		</section>
	</main>
</Layout>

<style>
	:global(*) {
		box-sizing: border-box;
	}

	:global(html) {
		background: #eef3f1;
	}

	:global(body) {
		font-family:
			"Segoe UI", Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
		background:
			linear-gradient(135deg, rgba(26, 91, 102, 0.16) 0%, rgba(26, 91, 102, 0) 34%),
			linear-gradient(180deg, #fbfcfc 0%, #eef3f1 52%, #f7f3f6 100%);
		color: #202428;
	}

	a {
		color: #235c68;
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}

	.page-shell {
		width: min(1100px, calc(100% - 32px));
		margin: 0 auto;
		padding: 28px 0 56px;
	}

	.hero {
		position: relative;
		overflow: hidden;
		display: grid;
		grid-template-columns: minmax(0, 1fr) 320px;
		gap: 36px;
		align-items: stretch;
		padding: 48px;
		border: 1px solid rgba(26, 91, 102, 0.16);
		border-radius: 8px;
		background: #12343b;
		box-shadow: 0 24px 70px rgba(18, 52, 59, 0.22);
	}

	.hero::before {
		content: "";
		position: absolute;
		inset: 0 auto 0 0;
		width: 10px;
		background: #b86b77;
	}

	.hero::after {
		content: "";
		position: absolute;
		right: -120px;
		top: -160px;
		width: 360px;
		height: 360px;
		border: 1px solid rgba(255, 255, 255, 0.16);
		border-radius: 50%;
	}

	.hero-copy {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.eyebrow {
		margin: 0 0 14px;
		font-size: 0.78rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #f2c4cb;
	}

	.period {
		display: inline-flex;
		width: fit-content;
		margin: 0 0 11px;
		padding: 5px 9px;
		border-radius: 999px;
		background: #e8f4f2;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: #1f6670;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		max-width: 780px;
		margin-bottom: 14px;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(3rem, 7vw, 5.7rem);
		line-height: 0.98;
		font-weight: 700;
		color: #ffffff;
	}

	.title {
		margin-bottom: 24px;
		font-size: clamp(1.15rem, 2vw, 1.45rem);
		font-weight: 650;
		color: #d7eeea;
	}

	.summary {
		max-width: 720px;
		margin-bottom: 0;
		font-size: 1.03rem;
		line-height: 1.75;
		color: #eef6f4;
	}

	.contact-panel {
		position: relative;
		z-index: 1;
		display: grid;
		align-content: center;
		gap: 16px;
		padding: 24px;
		border: 1px solid rgba(255, 255, 255, 0.3);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.94);
		font-size: 0.94rem;
	}

	.monogram {
		display: grid;
		place-items: center;
		width: 72px;
		height: 72px;
		margin-bottom: 2px;
		border-radius: 50%;
		background: #b86b77;
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.65rem;
		font-weight: 700;
		color: #ffffff;
	}

	.panel-label {
		margin: 0;
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.11em;
		text-transform: uppercase;
		color: #1f6670;
	}

	dl {
		display: grid;
		gap: 16px;
		margin: 0;
	}

	dt {
		margin-bottom: 4px;
		font-size: 0.72rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: #65757a;
	}

	dd {
		margin: 0;
		line-height: 1.45;
		color: #27343a;
	}

	.content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.55fr) minmax(270px, 0.75fr);
		gap: 34px;
		padding-top: 36px;
	}

	.section-block {
		margin-bottom: 28px;
		padding: 28px;
		border: 1px solid rgba(26, 91, 102, 0.12);
		border-radius: 8px;
		background: rgba(255, 255, 255, 0.92);
		box-shadow: 0 14px 35px rgba(18, 52, 59, 0.08);
	}

	h2 {
		display: flex;
		align-items: center;
		gap: 12px;
		margin-bottom: 24px;
		font-size: 0.92rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #1f6670;
	}

	h2::after {
		content: "";
		flex: 1;
		height: 1px;
		background: rgba(31, 102, 112, 0.18);
	}

	h3 {
		margin-bottom: 7px;
		font-family: Georgia, "Times New Roman", serif;
		font-size: 1.24rem;
		font-weight: 700;
		color: #18323a;
	}

	.timeline-item,
	.project-item {
		position: relative;
		padding: 0 0 24px 26px;
		margin-bottom: 24px;
		border-left: 2px solid #b8d5d1;
		border-bottom: 1px solid #e2e9e7;
	}

	.timeline-item::before,
	.project-item::before {
		content: "";
		position: absolute;
		top: 7px;
		left: -6px;
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background: #b86b77;
		box-shadow: 0 0 0 5px #ffffff;
	}

	.timeline-item p,
	.project-item p {
		line-height: 1.65;
		color: #4b5963;
	}

	.place {
		margin-bottom: 10px;
		font-weight: 700;
		color: #45646a;
	}

	.tag-list {
		display: grid;
		gap: 11px;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.tag-list li {
		padding: 11px 12px;
		border: 1px solid #d8e5e2;
		border-radius: 8px;
		background: #f8fbfa;
		color: #35434a;
	}

	.tag-list.compact li {
		font-size: 0.93rem;
		line-height: 1.45;
	}

	@media (max-width: 760px) {
		.page-shell {
			width: min(100% - 24px, 1120px);
			padding-top: 12px;
		}

		.hero,
		.content-grid {
			grid-template-columns: 1fr;
		}

		.hero {
			gap: 24px;
			padding: 28px 22px;
		}

		.contact-panel {
			width: 100%;
		}

		.section-block {
			padding: 22px;
		}
	}
</style>
